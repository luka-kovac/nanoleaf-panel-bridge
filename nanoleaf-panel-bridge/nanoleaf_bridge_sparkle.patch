+    def apply_bridge_effect_to_snapshot(
+        self,
+        state_snapshot: Dict[int, dict],
+    ) -> Dict[int, dict]:
+        with self.lock:
+            bridge_effect = self.bridge_effect
+
+        if bridge_effect == SPARKLE_EFFECT_NAME:
+            return self.apply_sparkle_effect_to_snapshot(state_snapshot)
+
